# ============================================
# VoteGuide AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# Add .env to your .gitignore (already done).

# ── Firebase Configuration ──
# (client-side — safe to be public, restricted by Firebase security rules)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# ── Google Gemini AI ──
# SERVER-SIDE ONLY — used in Cloud Functions, NEVER in client-side code
GEMINI_API_KEY_PRIMARY=your_primary_gemini_key
GEMINI_API_KEY_BACKUP=your_backup_gemini_key

# ── Firebase App Check ──
# reCAPTCHA Enterprise site key (client-side, safe to expose)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# ── Deployment & Runtime ──
NODE_ENV=production
CORS_ORIGIN=https://election-process-app.web.app

# ── Rate Limiting (Cloud Functions) ──
# Maximum AI requests per user per minute
RATE_LIMIT_AI_RPM=10
# Maximum vote submissions per session
RATE_LIMIT_VOTE_MAX=1

# ── Optional: Debug & Logging ──
# Set to 'true' to enable verbose Cloud Function logs (dev only)
DEBUG_LOGGING=false

# ============================================
# Setup Instructions:
# 1. cp .env.example .env
# 2. Fill in all required values above
# 3. For Cloud Functions secrets:
#    firebase functions:config:set gemini.key="YOUR_KEY"
# 4. For local emulator:
#    Add values to functions/.runtimeconfig.json
# See CONTRIBUTING.md for full setup guide.
# ============================================
