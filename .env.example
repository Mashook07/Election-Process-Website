# ============================================
# VoteGuide AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# Firebase Configuration (client-side — safe to be public)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Google Gemini AI API Keys (SERVER-SIDE ONLY — Cloud Functions)
# NEVER expose these in client-side code
GEMINI_API_KEY_PRIMARY=your_primary_gemini_key
GEMINI_API_KEY_BACKUP=your_backup_gemini_key

# Firebase App Check (reCAPTCHA Enterprise)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Deployment
NODE_ENV=production
CORS_ORIGIN=https://election-process-app.web.app

# ============================================
# Usage:
# - For Cloud Functions: firebase functions:config:set gemini.key="YOUR_KEY"
# - For local dev: set values in .runtimeconfig.json
# ============================================
