rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    // ── Users Collection ──
    // Users can only read/write their own document
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        // Prevent users from self-promoting their role
        || request.auth.token.admin == true;
      allow delete: if false; // Users cannot delete their accounts from client
    }

    // ── Votes Collection ──
    // Write-once, no individual reads (privacy protection)
    // Only aggregation via Cloud Functions
    match /votes/{voteId} {
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['encryptedVote', 'integrityHash', 'electionId', 'timestamp', 'anonymousToken'])
        && request.resource.data.electionId is string
        && request.resource.data.timestamp is int;
      allow read: if false;    // No client reads — privacy critical
      allow update: if false;  // Votes are immutable
      allow delete: if false;  // Votes cannot be deleted
    }

    // ── Voter Status Collection ──
    // Tracks whether a user has voted (without revealing the vote)
    match /voter_status/{statusId} {
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['hashedUserId', 'electionId', 'votedAt']);
      allow read: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── Voter Verifications Collection ──
    match /voter_verifications/{verificationId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'hashedGovId', 'idType', 'fullName', 'status']);
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow update: if false; // Verifications are immutable
      allow delete: if false;
    }

    // ── Blockchain Ledger Collection ──
    // Append-only — critical for integrity
    match /blockchain_ledger/{blockId} {
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['index', 'timestamp', 'dataHash', 'previousHash', 'hash', 'nonce']);
      allow read: if true;     // Public read for transparency
      allow update: if false;  // Blocks are immutable
      allow delete: if false;  // Blocks cannot be deleted
    }

    // ── Audit Logs Collection ──
    // Write-only from clients, read only by admin via Cloud Functions
    match /audit_logs/{logId} {
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['eventType', 'hashedUserId', 'timestamp', 'severity']);
      allow read: if isAuthenticated(); // In production: admin-only via custom claims
      allow update: if false;
      allow delete: if false;
    }

    // ── Elections Collection ──
    // Read-only for voters, write for admins only
    match /elections/{electionId} {
      allow read: if true; // Public election info
      allow write: if false; // Admin-only via Cloud Functions
    }

    // ── Default Deny ──
    // All other collections are denied by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
